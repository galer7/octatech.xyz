---
/**
 * Simplified contact form — name, email, message only
 * Keeps honeypot and API submission to api.octatech.xyz
 */
---

<section id="contact" class="max-w-7xl mx-auto px-6 mt-16 scroll-mt-20">
  <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-10">
    <div class="text-center mb-8">
      <h3 class="text-2xl md:text-3xl font-semibold tracking-tight">Get in Touch</h3>
      <p class="text-white/70 mt-2">Have a project in mind? I'll get back to you within 24 hours.</p>
    </div>

    <form id="contactForm" class="max-w-xl mx-auto" novalidate>
      <div class="space-y-5">
        <div class="flex flex-col gap-2">
          <label for="contact-name" class="text-sm font-medium text-white/90">
            Name <span class="text-red-400">*</span>
          </label>
          <input type="text" id="contact-name" name="name" required minlength="2" placeholder="Your name"
            aria-required="true" aria-describedby="name-error"
            class="h-11 px-4 rounded-xl border border-white/10 bg-white/[0.02] text-white placeholder-white/40 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition">
          <p id="name-error" class="text-red-400 text-xs hidden" role="alert"></p>
        </div>

        <div class="flex flex-col gap-2">
          <label for="contact-email" class="text-sm font-medium text-white/90">
            Email <span class="text-red-400">*</span>
          </label>
          <input type="email" id="contact-email" name="email" required placeholder="you@example.com"
            aria-required="true" aria-describedby="email-error"
            class="h-11 px-4 rounded-xl border border-white/10 bg-white/[0.02] text-white placeholder-white/40 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition">
          <p id="email-error" class="text-red-400 text-xs hidden" role="alert"></p>
        </div>

        <div class="flex flex-col gap-2">
          <label for="contact-message" class="text-sm font-medium text-white/90">
            Message <span class="text-red-400">*</span>
          </label>
          <textarea id="contact-message" name="message" required minlength="10" rows="5"
            placeholder="Tell me about your project..." aria-required="true"
            aria-describedby="message-error"
            class="px-4 py-3 rounded-xl border border-white/10 bg-white/[0.02] text-white placeholder-white/40 focus:outline-none focus:border-indigo-500/50 focus:ring-2 focus:ring-indigo-500/20 transition resize-none"></textarea>
          <p id="message-error" class="text-red-400 text-xs hidden" role="alert"></p>
        </div>
      </div>

      <!-- Honeypot -->
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <label for="website">Website (leave blank)</label>
        <input type="text" name="website" id="website" tabindex="-1" autocomplete="off">
      </div>

      <div id="form-error"
        class="mt-6 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm hidden" role="alert">
        <p id="form-error-text"></p>
      </div>

      <div class="mt-8 flex justify-center">
        <button type="submit" id="contact-submit"
          class="inline-flex items-center justify-center h-12 px-8 rounded-xl bg-indigo-500 text-white font-medium hover:bg-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:ring-offset-2 focus:ring-offset-neutral-950 transition disabled:opacity-50 disabled:cursor-not-allowed">
          <span id="submit-text">Send Message</span>
          <svg id="submit-spinner" class="hidden ml-2 h-5 w-5 animate-spin" xmlns="http://www.w3.org/2000/svg"
            fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
            </path>
          </svg>
        </button>
      </div>
    </form>

    <div id="contact-success" class="hidden max-w-xl mx-auto text-center py-12">
      <div
        class="inline-flex items-center justify-center h-16 w-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 mb-6">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
          <path
            d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
            fill="currentColor" fill-opacity="0.4" />
          <path d="M7 12L10 15L17 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" />
        </svg>
      </div>
      <h4 class="text-2xl font-semibold tracking-tight mb-2">Thank you!</h4>
      <p class="text-white/70">I've received your message and will get back to you within 24 hours.</p>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('contact-submit');
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');
    const formError = document.getElementById('form-error');
    const formErrorText = document.getElementById('form-error-text');
    const successMessage = document.getElementById('contact-success');

    const nameInput = document.getElementById('contact-name');
    const emailInput = document.getElementById('contact-email');
    const messageInput = document.getElementById('contact-message');
    const honeypotInput = document.getElementById('website');

    const nameError = document.getElementById('name-error');
    const emailError = document.getElementById('email-error');
    const messageError = document.getElementById('message-error');

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function clearFieldError(errorEl, inputEl) {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
      inputEl.classList.remove('border-red-500/50');
      inputEl.removeAttribute('aria-invalid');
    }

    function showFieldError(errorEl, inputEl, msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
      inputEl.classList.add('border-red-500/50');
      inputEl.setAttribute('aria-invalid', 'true');
    }

    function clearAllErrors() {
      clearFieldError(nameError, nameInput);
      clearFieldError(emailError, emailInput);
      clearFieldError(messageError, messageInput);
      formError.classList.add('hidden');
    }

    function validateForm() {
      let valid = true;
      clearAllErrors();

      if (!nameInput.value.trim() || nameInput.value.trim().length < 2) {
        showFieldError(nameError, nameInput, 'Please enter your name (at least 2 characters)');
        valid = false;
      }
      if (!emailInput.value.trim() || !emailRegex.test(emailInput.value.trim())) {
        showFieldError(emailError, emailInput, 'Please enter a valid email address');
        valid = false;
      }
      if (!messageInput.value.trim() || messageInput.value.trim().length < 10) {
        showFieldError(messageError, messageInput, 'Please enter a message (at least 10 characters)');
        valid = false;
      }
      return valid;
    }

    function setLoading(loading) {
      submitBtn.disabled = loading;
      submitText.textContent = loading ? 'Sending...' : 'Send Message';
      submitSpinner.classList.toggle('hidden', !loading);
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      if (!validateForm()) return;
      if (honeypotInput.value) {
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
        return;
      }

      setLoading(true);
      clearAllErrors();

      const formData = {
        name: nameInput.value.trim(),
        email: emailInput.value.trim(),
        message: messageInput.value.trim(),
        honeypot: honeypotInput.value
      };

      try {
        const response = await fetch('https://api.octatech.xyz/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });

        const data = await response.json();

        if (response.ok && data.success) {
          form.classList.add('hidden');
          successMessage.classList.remove('hidden');
        } else if (response.status === 400 && data.errors) {
          if (data.errors.name) showFieldError(nameError, nameInput, data.errors.name);
          if (data.errors.email) showFieldError(emailError, emailInput, data.errors.email);
          if (data.errors.message) showFieldError(messageError, messageInput, data.errors.message);
          if (!data.errors.name && !data.errors.email && !data.errors.message) {
            formErrorText.textContent = data.message || 'Please check your input and try again.';
            formError.classList.remove('hidden');
          }
        } else {
          formErrorText.textContent = data.message || 'Something went wrong. Please try again later.';
          formError.classList.remove('hidden');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        formErrorText.textContent = 'Unable to submit form. Please check your connection and try again.';
        formError.classList.remove('hidden');
      } finally {
        setLoading(false);
      }
    });

    // Real-time validation on blur
    nameInput.addEventListener('blur', function () {
      if (this.value.trim() && this.value.trim().length < 2)
        showFieldError(nameError, nameInput, 'Please enter your name (at least 2 characters)');
      else if (this.value.trim()) clearFieldError(nameError, nameInput);
    });

    emailInput.addEventListener('blur', function () {
      if (this.value.trim() && !emailRegex.test(this.value.trim()))
        showFieldError(emailError, emailInput, 'Please enter a valid email address');
      else if (this.value.trim()) clearFieldError(emailError, emailInput);
    });

    messageInput.addEventListener('blur', function () {
      if (this.value.trim() && this.value.trim().length < 10)
        showFieldError(messageError, messageInput, 'Please enter a message (at least 10 characters)');
      else if (this.value.trim()) clearFieldError(messageError, messageInput);
    });

    // Clear errors on input
    nameInput.addEventListener('input', function () {
      if (nameError.textContent && this.value.trim().length >= 2) clearFieldError(nameError, nameInput);
    });
    emailInput.addEventListener('input', function () {
      if (emailError.textContent && emailRegex.test(this.value.trim())) clearFieldError(emailError, emailInput);
    });
    messageInput.addEventListener('input', function () {
      if (messageError.textContent && this.value.trim().length >= 10) clearFieldError(messageError, messageInput);
    });
  })();
</script>
