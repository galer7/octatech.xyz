<section id="expertise" class="max-w-7xl mx-auto px-6 mt-16 scroll-mt-20">
  <div class="rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:p-8">
    <div class="mb-6">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">What I Know</h2>
      <p class="text-white/70 mt-2">7 years of building production software.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {areas.map((area) => (
        <div class="flex items-start gap-4">
          <span
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-500/10 border border-indigo-500/20 text-indigo-400">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" set:html={area.icon} />
          </span>
          <div>
            <h3 class="text-base font-semibold tracking-tight">{area.title}</h3>
            <p class="text-sm text-white/70 mt-1 leading-relaxed">{area.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
